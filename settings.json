            "fieldset": "footer"
        },
        {
            "id": "youtube",
            "label": "YouTube URL",
            "type": "text",
            "description": "Example: https://youtube.com/@shoppego",
            "default": "https://youtube.com/@#",
            "fieldset": "footer"
        },
        {
            "id": "threads",
            "label": "Threads URL",
            "type": "text",
            "description": "Example: https://threads.net/@shoppego",
            "default": "https://threads.net/@#",
            "fieldset": "footer"
        },
        {
            "id": "custom_css",
            "label": "Custom CSS style",
            "type": "textarea",
            "rows": 2,
            "description": "Example : .footer { color:black; }",
            "fieldset": "theme"
        },
        {
            "id": "custom_meta",
            "label": "Custom Meta Tags",
            "type": "textarea",
            "rows": 2,
            "description": "Example: <meta name='google-site-verification' content='absDfGH-AbCDFgy_wQGCZ9ImAsaGRnBbpDfWnokyfGc'>",
            "fieldset": "theme"
        },
        {
            "id": "whatsapp_number",
            "label": "WhatsApp Number",
            "type": "text",
            "description": "Phone number with country code (e.g., 60123456789). Leave empty to hide.",
            "default": "",
            "fieldset": "livechat"
        },
        {
            "id": "whatsapp_heading",
            "label": "Widget Heading",
            "type": "text",
            "description": "Heading text for the chat widget",
            "default": "Got a question?",
            "fieldset": "livechat"
        },
        {
            "id": "whatsapp_description",
            "label": "Widget Description",
            "type": "text",
            "description": "Description text below the heading",
            "default": "Chat with us directly anytime. We'd love to hear from you.",
            "fieldset": "livechat"
        },
        {
            "id": "whatsapp_response_time",
            "label": "Response Time Text",
            "type": "text",
            "description": "Status text showing response time",
            "default": "We reply quickly during working hours",
            "fieldset": "livechat"
        },
        {
            "id": "whatsapp_button_text",
            "label": "Button Text",
            "type": "text",
            "description": "Text for the WhatsApp chat button",
            "default": "Chat on WhatsApp",
            "fieldset": "livechat"
        },
        {
            "id": "whatsapp_default_message",
            "label": "Default Message",
            "type": "text",
            "description": "Pre-filled message when opening WhatsApp chat",
            "default": "Hi, I have a question about",
            "fieldset": "livechat"
        },
        {
            "id": "messenger_username",
            "label": "Messenger Username",
            "type": "text",
            "description": "Your Facebook page username without @ (e.g., shoppego). Leave empty to hide.",
            "default": "",
            "fieldset": "livechat"
        },
        {
            "id": "instagram_username",
            "label": "Instagram Username",
            "type": "text",
            "description": "Your Instagram username without @ (e.g., shoppego). Leave empty to hide.",
            "default": "",
            "fieldset": "livechat"
        },
        {
            "id": "powered_by_shoppego",
            "label": "Powered by Shoppego",
            "type": "boolean",
            "default": false,
            "description": "Hide powered by Shoppego text",
            "fieldset": "footer"
