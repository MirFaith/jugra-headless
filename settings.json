        },
        {
            "id": "category_3_link",
            "label": "Category 3 Link",
            "type": "text",
            "description": "URL for third featured category",
            "default": "/categories/featured",
            "fieldset": "categories"
        },
        {
            "id": "category_3_description",
            "label": "Category 3 Description",
