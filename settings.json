{
    "fieldsets": [
        {
            "id": "header",
            "label": "Header"
        },
        {
            "id": "hero",
            "label": "Featured banner"
        },
        {
            "id": "categories",
            "label": "Featured categories"
        },
        {
            "id": "footer",
            "label": "Footer"
        },
        {
            "id": "livechat",
            "label": "Livechat widget"
        },
        {
            "id": "theme",
            "label": "Theme settings"
        }
    ],

    "images": [
        {
            "id": "header_logo",
            "label": "Logo",
            "description": "Your store logo",
            "fieldset": "header"
        },
        {
            "id": "favourite_icon",
            "label": "Favicon",
            "description": "Good for an image up to 30x30 px",
            "fieldset": "theme"
        },
        {
            "id": "hero_image",
            "label": "Hero 1 Image",
            "description": "Upload hero banner image (recommended size: 1080x1350px, 4:5 ratio)",
            "fieldset": "hero"
        },
        {
            "id": "hero_2_image",
            "label": "Hero 2 Image",
            "description": "Upload hero banner image (recommended size: 1080x1350px, 4:5 ratio)",
            "fieldset": "hero"
        },
        {
            "id": "category_1_image",
            "label": "Category 1 Image",
            "description": "Upload image for first featured category",
            "fieldset": "categories"
        },
        {
            "id": "category_2_image",
            "label": "Category 2 Image",
            "description": "Upload image for second featured category",
            "fieldset": "categories"
        },
        {
            "id": "category_3_image",
            "label": "Category 3 Image",
            "description": "Upload image for third featured category",
            "fieldset": "categories"
        },
        {
            "id": "og_image_custom",
            "label": "Social Share Image",
            "description": "Default image for social media sharing (recommended size: 1200x630px)",
            "fieldset": "theme"
        }
