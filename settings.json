            "fieldset": "theme"
        },
        {
            "id": "cart_instruction",
            "label": "Cart Instruction",
            "type": "text",
            "description": "Instruction text shown on cart page",
            "fieldset": "theme"
        },
        {
            "id": "company_id",
            "label": "Company ID",
            "type": "text",
            "description": "Company registration number",
            "default": "",
            "fieldset": "footer"
        },
        {
            "id": "facebook",
            "label": "Facebook URL",
            "type": "text",
            "description": "Example: https://facebook.com/shoppego",
            "default": "https://facebook.com/#",
            "fieldset": "footer"
        },
        {
            "id": "instagram",
            "label": "Instagram URL",
            "type": "text",
            "description": "Example: https://instagram.com/shoppego",
            "default": "https://instagram.com/#",
            "fieldset": "footer"
        },
        {
            "id": "twitter",
            "label": "X (Twitter) URL",
            "type": "text",
            "description": "Example: https://x.com/shoppego",
            "default": "https://x.com/#",
            "fieldset": "footer"
        },
        {
            "id": "tiktok",
            "label": "TikTok URL",
            "type": "text",
            "description": "Example: https://tiktok.com/@shoppego",
