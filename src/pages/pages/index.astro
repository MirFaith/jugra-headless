---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/content/PageHeader.astro';
import { PageService, StoreService } from '@services/index';
import { pagePath } from '@utils/routes';

const [store, pages] = await Promise.all([
  StoreService.getStore(),
  PageService.list()
]);
---

<BaseLayout title={`Pages | ${store.name}`} description={`Browse information pages from ${store.name}.`}>
  <main>
    <section class="min-h-[70vh] bg-card py-10 md:py-16">
      <div class="mx-auto max-w-6xl px-5">
        <PageHeader
          eyebrow="Pages"
          title="Store information"
          description={`Helpful customer pages from ${store.name}.`}
        />
        <div class="grid gap-4 md:grid-cols-2">
          {pages.map((page) => (
            <a href={pagePath(page.slug)} class="block border border-secondary-border/40 p-6 transition-colors hover:border-primary">
              <h2 class="mb-2 font-display text-2xl font-semibold text-accent">{page.title}</h2>
              <p class="text-sm leading-relaxed text-secondary">View page</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
