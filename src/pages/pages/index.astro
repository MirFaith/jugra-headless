---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/content/PageHeader.astro';
import { StoreService } from '@services/index';
import { staticPages, type StaticPage } from '@data/staticPages';

const store = await StoreService.getStore();
---

<BaseLayout title={`Pages | ${store.name}`} description={`Browse information pages from ${store.name}.`}>
  <main>
    <section class="min-h-[70vh] bg-card py-10 md:py-16">
      <div class="mx-auto max-w-6xl px-5">
        <PageHeader
          eyebrow="Pages"
          title="Store information"
          description="Helpful customer pages and fallback content routes for menu links."
        />
        <div class="grid gap-4 md:grid-cols-2">
          {staticPages.map((page: StaticPage) => (
            <a href={`/pages/${page.slug}`} class="block border border-secondary-border/40 p-6 transition-colors hover:border-primary">
              <h2 class="mb-2 font-display text-2xl font-semibold text-accent">{page.title}</h2>
              <p class="text-sm leading-relaxed text-secondary">{page.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
