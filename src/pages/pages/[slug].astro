---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/content/PageHeader.astro';
import { PageService, StoreService } from '@services/index';
import { sanitizeHtml } from '@utils/sanitize';

export async function getStaticPaths() {
  const pages = await PageService.list();

  return pages.map((page) => ({
    params: { slug: page.slug }
  }));
}

const { slug } = Astro.params;
const [store, page] = await Promise.all([
  StoreService.getStore(),
  PageService.getBySlug(slug as string)
]);

const builder = page.metafields?.builder;
const builderCss = typeof builder === 'object' && builder !== null && 'css' in builder && typeof builder.css === 'string'
  ? builder.css
  : '';
const builderJs = typeof builder === 'object' && builder !== null && 'js' in builder && typeof builder.js === 'string'
  ? builder.js
  : '';
const isBuilderPage = Boolean(builderCss || builderJs || page.template === 'builder');
const description = page.body?.replace(/<[^>]*>/g, '').slice(0, 150) || `Read ${page.title} from ${store.name}.`;
---

<BaseLayout title={`${page.title} | ${store.name}`} description={description}>
  <main>
    {isBuilderPage ? (
      <section class="min-h-[70vh] bg-card">
        {builderCss && <style is:inline set:html={builderCss} />}
        <div class="jugra-builder-content" set:html={sanitizeHtml(page.body)} />
        {builderJs && <script is:inline set:html={builderJs} />}
      </section>
    ) : (
      <section class="min-h-[70vh] bg-card py-10 md:py-16">
        <div class="mx-auto max-w-4xl px-5">
          <PageHeader title={page.title} />
          {page.image && (
            <img src={page.image} alt={page.title} class="mb-8 w-full border border-secondary-border/30 object-cover" loading="eager" />
          )}
          <div class="jugra-rich-content text-secondary" set:html={sanitizeHtml(page.body)} />
        </div>
      </section>
    )}
  </main>
</BaseLayout>
