---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/content/PageHeader.astro';
import { StoreService } from '@services/index';
import { staticPages, type StaticPage } from '@data/staticPages';

export function getStaticPaths() {
  return staticPages.map((page: StaticPage) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props as { page: StaticPage };
const store = await StoreService.getStore();
---

<BaseLayout title={`${page.title} | ${store.name}`} description={page.description}>
  <main>
    <section class="min-h-[70vh] bg-card py-10 md:py-16">
      <div class="mx-auto max-w-4xl px-5">
        <PageHeader title={page.title} description={page.description} />
        <div class="space-y-8">
          {page.sections.map((section: StaticPage['sections'][number]) => (
            <section class="border-t border-secondary-border/40 pt-8">
              <h2 class="mb-3 font-display text-2xl font-semibold text-accent">{section.heading}</h2>
              <p class="leading-relaxed text-secondary">{section.body}</p>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
