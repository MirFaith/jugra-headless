---
import BaseLayout from '@layouts/BaseLayout.astro';
import CollectionRows from '@components/collection/CollectionRows.astro';
import Hero from '@components/home/Hero.astro';
import ProductGrid from '@components/product/ProductGrid.astro';
import { CollectionService, ProductService, StoreService } from '@services/index';

const [store, productEnvelope, collections] = await Promise.all([
  StoreService.getStore(),
  ProductService.list(1),
  CollectionService.list()
]);
const featuredProducts = productEnvelope.data.slice(0, 6);
const featuredCollections = collections.slice(0, 3);
---

<BaseLayout title={`${store.name} | Headless Storefront`} description={`Shop products from ${store.name}.`}>
  <main>
    <Hero />

    <section class="bg-card py-10 md:py-16" id="featured">
      <div class="mx-auto max-w-6xl px-5">
        <h2 class="mb-12 text-center font-display text-3xl font-semibold md:text-4xl">
          All Products
        </h2>
        <ProductGrid products={featuredProducts} currency={store.currency} />
        <div class="text-center">
          <a
            href="/products"
            class="inline-block border-2 border-primary px-8 py-3.5 text-xs font-semibold uppercase tracking-widest text-primary transition-all hover:bg-primary hover:text-white"
          >
            View All
          </a>
        </div>
      </div>
    </section>

    {featuredCollections.length > 0 && (
      <section class="bg-card py-16 md:py-20">
        <div class="mx-auto max-w-6xl px-5">
          <h2 class="mb-12 text-center font-display text-3xl font-semibold md:text-4xl">
            Our collections
          </h2>
          <CollectionRows collections={featuredCollections} />
        </div>
      </section>
    )}
  </main>
</BaseLayout>
