---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/content/PageHeader.astro';
import { StoreService } from '@services/index';

const store = await StoreService.getStore();
---

<BaseLayout title={`Page not found | ${store.name}`} description={`The requested page could not be found on ${store.name}.`}>
  <main>
    <section class="min-h-[70vh] bg-card py-16 md:py-24">
      <div class="mx-auto max-w-4xl px-5 text-center">
        <PageHeader
          eyebrow="404"
          title="Page not found"
          description="The page you are looking for is no longer available or may have moved."
        />
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/" class="inline-flex min-h-11 items-center justify-center border border-accent px-6 text-xs font-semibold uppercase tracking-widest text-accent transition-colors hover:bg-accent hover:text-card">
            Home
          </a>
          <a href="/products" class="inline-flex min-h-11 items-center justify-center border border-secondary-border px-6 text-xs font-semibold uppercase tracking-widest text-accent transition-colors hover:border-accent">
            Products
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
