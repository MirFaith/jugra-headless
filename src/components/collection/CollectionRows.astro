---
import type { ShoppegoCollection } from '@models/shoppego';
import { collectionPath } from '@utils/routes';

interface Props {
  collections: ShoppegoCollection[];
}

const { collections } = Astro.props;
---

<div class="space-y-12 md:space-y-16">
  {collections.map((collection, index) => {
    const isEven = (index + 1) % 2 === 0;

    return (
      <div class="grid grid-cols-1 items-center gap-8 md:grid-cols-2 md:gap-20">
        <div class:list={[isEven && 'md:order-2']}>
          <a href={collectionPath(collection)} class="group block">
            <div class="relative aspect-square overflow-hidden bg-secondary-border/20"></div>
          </a>
        </div>
        <div class:list={[isEven && 'md:order-1', 'text-center md:text-left']}>
          <h3 class="mb-4 font-display text-2xl font-semibold text-accent md:text-3xl">
            {collection.name}
          </h3>
          <a
            href={collectionPath(collection)}
            class="inline-block border-2 border-primary px-8 py-3.5 text-xs font-semibold uppercase tracking-widest text-primary transition-all hover:bg-primary hover:text-white"
          >
            View collection
          </a>
        </div>
      </div>
    );
  })}
</div>
