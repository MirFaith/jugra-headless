---
import type { ShoppegoCollection } from '@models/shoppego';
import { collectionPath } from '@utils/routes';

interface Props {
  collection: ShoppegoCollection;
}

const { collection } = Astro.props;
---

<a href={collectionPath(collection)} class="group block border border-secondary-border/50 p-6 transition-colors hover:border-primary">
  <h2 class="mb-2 font-display text-2xl font-semibold text-accent transition-colors group-hover:text-primary">
    {collection.name}
  </h2>
  <p class="text-sm text-secondary">View collection</p>
</a>
