<div id="search-modal" class="invisible fixed inset-0 z-50 bg-dark-primary/30 opacity-0 backdrop-blur-sm transition-all duration-300">
  <div id="search-modal-panel" class="fixed left-0 right-0 top-0 -translate-y-full bg-card shadow-lg transition-transform duration-300 ease-out">
    <div class="mx-auto max-w-4xl px-5 py-8">
      <form action="/search" method="get" class="flex items-center gap-4">
        <div class="relative flex-1">
          <label class="sr-only" for="search-input">Search products</label>
          <input
            type="text"
            id="search-input"
            name="q"
            placeholder="Search products..."
            class="w-full rounded-lg border-2 border-secondary-border/30 px-6 py-4 text-base focus:border-primary focus:outline-none"
          />
          <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-accent hover:text-primary" aria-label="Submit search">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="11" cy="11" r="8" stroke-width="1.8"></circle>
              <path d="m21 21-4.35-4.35" stroke-width="1.8" stroke-linecap="round"></path>
            </svg>
          </button>
        </div>
        <button id="search-modal-close" type="button" class="text-accent hover:text-primary" aria-label="Close search">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>
