---
interface Props {
  query?: string;
  count: number;
}

const { query = '', count } = Astro.props;
---

{query && count === 0 && (
  <div class="min-h-[80vh] py-12 text-center">
    <h2 class="mb-6 font-display text-8xl font-bold text-accent md:text-9xl">
      Oops!
    </h2>
    <h3 class="mb-4 font-display text-2xl font-semibold text-accent md:text-3xl">
      Search not found
    </h3>
    <p class="mb-8 text-secondary">
      We found <span>{count}</span> results for your search keyword "<span class="font-bold">{query}</span>"
    </p>
    <a
      href="/products"
      class="inline-block border-2 border-primary bg-transparent px-8 py-3.5 text-xs font-semibold uppercase tracking-widest text-primary transition-all hover:bg-primary hover:text-white"
    >
      View All Products
    </a>
  </div>
)}

{query && count > 0 && (
  <div class="mb-8 text-left">
    <p class="text-secondary">
      We found <span>{count}</span> result{count === 1 ? '' : 's'} for your search "<span class="font-bold">{query}</span>"
    </p>
  </div>
)}
