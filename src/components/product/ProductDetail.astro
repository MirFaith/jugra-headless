---
import type { ShoppegoCurrency, ShoppegoProduct, ShoppegoProductOption, ShoppegoProductVariant } from '@models/shoppego';
import { formatMoney } from '@utils/money';
import { collectionPath } from '@utils/routes';
import { sanitizeHtml } from '@utils/sanitize';

interface Props {
  product: ShoppegoProduct;
  currency: ShoppegoCurrency;
}

const { product, currency } = Astro.props;
const firstVariant = product.selected_or_first_available_variant?.id
  ? product.variants.find((variant) => variant.id === product.selected_or_first_available_variant?.id) || product.selected_or_first_available_variant
  : product.variants.find((variant) => variant.available) || product.variants[0];
const images = Array.from(new Set([
  product.featured_image,
  ...product.images,
  ...product.variants.map((variant) => variant.image || null)
].filter((image): image is string => Boolean(image))));
const productCollections = product.collections || [];
const reviews = product.reviews || [];
const reviewCount = reviews.length;
const averageRating = reviewCount
  ? reviews.reduce((total, review) => total + Math.max(0, Math.min(5, Number(review.rating) || 0)), 0) / reviewCount
  : 0;
const roundedAverageRating = Math.round(averageRating);
const wholesalePrices = product.wholesale_prices || [];
const bundleProducts = product.bundle_products || [];
const selectableOptions = product.options.filter((option) => {
  return ['radio', 'select', 'swatch'].includes(option.type) && option.name !== 'Default' && !product.has_only_default_variant;
});
const customOptions = product.options.filter((option) => {
  return ['date', 'datetime', 'input', 'textarea'].includes(option.type);
});
const isBundle = Boolean(product.is_bundle && bundleProducts.length > 0);
const initialPrice = firstVariant?.price ?? product.price;
const initialCompare = firstVariant?.compare_at_price ?? (
  product.compare_at_price_max && product.compare_at_price_max > product.price ? product.compare_at_price_max : null
);
const bundleSavedAmount = initialCompare && initialCompare > initialPrice ? initialCompare - initialPrice : 0;
const productJson = JSON.stringify(product);
const currencyJson = JSON.stringify(currency);

function optionValueIsAvailable(option: ShoppegoProductOption, value: string) {
  return product.variants.some((variant) => variant.available && variant.options[option.name] === value);
}

function optionType(type: string): 'date' | 'datetime-local' | 'text' {
  if (type === 'date') return 'date';
  if (type === 'datetime') return 'datetime-local';
  return 'text';
}

function variantOptionsLabel(variant: ShoppegoProductVariant) {
  return Object.entries(variant.options)
    .filter(([name, value]) => name !== 'Default' && value !== 'Default')
    .map(([name, value]) => `${name}: ${value}`)
    .join(', ');
}

function bundleImage(bundleProduct: { featured_image: string | null; images: string[]; selected_or_first_available_variant: ShoppegoProductVariant | null }) {
  return bundleProduct.selected_or_first_available_variant?.image || bundleProduct.featured_image || bundleProduct.images[0] || null;
}

function variantComparePrice(variant: ShoppegoProductVariant | null | undefined) {
  return variant?.compare_at_price && variant.compare_at_price > variant.price ? variant.compare_at_price : null;
}

function optionValueImage(option: ShoppegoProductOption, value: string) {
  return product.variants.find((variant) => variant.options?.[option.name] === value && variant.image)?.image || null;
}

function reviewDate(value: string) {
  const dateMatch = value.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (dateMatch) return `${dateMatch[3]}/${dateMatch[2]}/${dateMatch[1]}`;
  return value;
}

---

<section class="bg-card py-0 md:py-16">
  <div class="mx-auto max-w-6xl md:px-5">
    <div class="grid grid-cols-1 gap-0 md:gap-8 lg:grid-cols-2 lg:gap-12">
      <div class="product-images">
        <div class="relative">
          <div class="relative mb-0 overflow-hidden bg-secondary-border/20 md:mb-2" id="product-gallery-main">
            {images.length > 0 ? (
              images.map((image, index) => (
                <div class:list={['product-gallery-slide flex items-center justify-center', index !== 0 && 'hidden']} data-gallery-image={image}>
                  <img
                    src={image}
                    alt={`${product.name} - Image ${index + 1}`}
                    class="h-auto max-h-full w-full object-contain"
                    loading={index === 0 ? 'eager' : 'lazy'}
                  />
                </div>
              ))
            ) : (
              <div class="aspect-square w-full bg-secondary-border/20"></div>
            )}

            {images.length > 1 && (
              <>
                <button
                  type="button"
                  id="carousel-prev"
                  class="absolute left-4 top-1/2 z-10 flex -translate-y-1/2 items-center justify-center text-white/80 transition-all hover:text-white"
                  aria-label="Previous image"
                >
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                </button>
                <button
                  type="button"
                  id="carousel-next"
                  class="absolute right-4 top-1/2 z-10 flex -translate-y-1/2 items-center justify-center text-white/80 transition-all hover:text-white"
                  aria-label="Next image"
                >
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                </button>
              </>
            )}
          </div>

          {images.length > 1 && (
            <div class="flex gap-2 overflow-x-auto px-5 py-4 md:grid md:grid-cols-2 md:overflow-visible md:px-0 md:py-0">
              {images.map((image, index) => (
                <button
                  type="button"
                  class:list={[
                    'product-gallery-thumb h-16 w-16 flex-shrink-0 overflow-hidden border-2 bg-secondary-border/20 md:h-auto md:w-auto',
                    index === 0 ? 'border-secondary-border' : 'border-transparent'
                  ]}
                  data-gallery-index={index}
                  data-gallery-image={image}
                  aria-label={`View image ${index + 1}`}
                >
                  <img src={image} alt={`${product.name} thumbnail ${index + 1}`} class="h-full w-full object-cover md:h-auto" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="product-info px-5 py-8 md:px-0 md:py-0">
        <nav class="mb-4 text-sm" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-secondary">
            <li><span>Products</span></li>
            {productCollections[0] && (
              <>
                <li aria-hidden="true">&gt;</li>
                <li><a href={collectionPath(productCollections[0].slug)} class="hover:text-primary">{productCollections[0].name}</a></li>
              </>
            )}
          </ol>
        </nav>

        <h1 class="mb-2 font-display text-3xl font-semibold md:text-4xl">
          {product.name}
        </h1>

        {reviewCount > 0 && (
          <div class="mb-5 flex items-center gap-2 text-sm text-secondary">
            <span class="flex items-center gap-0.5" aria-label={`${averageRating.toFixed(1)} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, index) => (
                <span class={index < roundedAverageRating ? 'text-[#d9a441]' : 'text-secondary-border'} aria-hidden="true">★</span>
              ))}
            </span>
            <span>{averageRating.toFixed(0)} ({reviewCount} {reviewCount === 1 ? 'review' : 'reviews'})</span>
          </div>
        )}

        <div class="mb-2 flex items-center gap-3">
          <p
            id="product-compare-price"
            class:list={[
              'text-xl font-medium text-secondary line-through',
              !(initialCompare && initialCompare > initialPrice) && 'hidden'
            ]}
          >
            {initialCompare && initialCompare > initialPrice ? formatMoney(initialCompare, currency) : ''}
          </p>
          <p class="text-2xl font-medium text-accent" id="product-price">
            {formatMoney(initialPrice, currency)}
            {product.price_varies && <sup>+</sup>}
          </p>
        </div>

        <form
          id="product-form"
          data-bundle-checkout-url={isBundle ? '/api/bundle-checkout' : undefined}
          data-product={productJson}
          data-currency={currencyJson}
        >
          <input type="hidden" id="selected-variant-id" name="variant_id" value={selectableOptions.length > 0 ? '' : firstVariant?.id ?? ''} />
          {isBundle && <input type="hidden" name="product_id" value={product.id} />}
          {isBundle && <input type="hidden" name="product_url" value={product.url} />}
          <div id="product-alert" class="mb-4 hidden rounded border border-red-200 bg-red-50 p-3 text-sm text-red-700">
            Please select an option.
          </div>

          {isBundle && (
            <div id="bundles" class="mb-6 border border-secondary-border/40">
              <div class="border-b border-secondary-border/30 bg-secondary-border/5 px-4 py-3">
                <p id="bundle-saved-price" class="text-sm font-semibold text-accent">
                  {bundleSavedAmount > 0 ? `Save ${formatMoney(bundleSavedAmount, currency)} With This Bundle!` : 'Grab This Amazing Bundle Now!'}
                </p>
              </div>
              <ul class="product-bundle divide-y divide-secondary-border/30">
                {bundleProducts.map((bundleProduct, index) => {
                  const selectedVariant = bundleProduct.selected_or_first_available_variant || bundleProduct.variants.find((variant) => variant.available) || bundleProduct.variants[0] || null;
                  const image = bundleImage(bundleProduct);
                  const comparePrice = variantComparePrice(selectedVariant);

                  return (
                    <li
                      class="bundle-items p-4"
                      data-bundle-line
                      data-bundle-index={index}
                      data-bundle-product-id={bundleProduct.id}
                      data-bundle-product-name={bundleProduct.name}
                      data-bundle-product-image={image || ''}
                    >
                      <div class="flex gap-4">
                        <div class="bundle-thumbnails h-20 w-20 flex-shrink-0 bg-secondary-border/10">
                          {image ? (
                            <img src={image} alt={bundleProduct.name} class="h-full w-full object-cover" loading="lazy" />
                          ) : (
                            <div class="h-full w-full bg-secondary-border/20"></div>
                          )}
                        </div>
                        <div class="min-w-0 flex-1">
                          <h3 class="mb-2 text-base font-medium text-accent">{bundleProduct.name}</h3>
                          {selectedVariant && (
                            <div class="mb-3 text-sm">
                              <span
                                class:list={[
                                  'bundle-discount-price-single text-secondary line-through',
                                  !comparePrice && 'hidden'
                                ]}
                              >
                                {comparePrice ? formatMoney(comparePrice, currency) : ''}
                              </span>
                              <span class="bundle-price ml-1 text-accent">{formatMoney(selectedVariant.price, currency)}</span>
                              <p
                                class:list={[
                                  'bundle-saved-price-variant mb-1 text-xs text-green-700',
                                  !comparePrice && 'hidden'
                                ]}
                              >
                                {comparePrice ? `(Save ${formatMoney(comparePrice - selectedVariant.price, currency)})` : ''}
                              </p>
                            </div>
                          )}

                          {bundleProduct.variants.length > 1 ? (
                            <select class="bundle-variant-select mb-3 w-full border border-secondary-border bg-card px-3 py-3 text-sm focus:border-primary focus:outline-none" aria-label={`${bundleProduct.name} option`}>
                              <option value="">Please select</option>
                              {bundleProduct.variants.map((variant) => (
                                <option
                                  value={variant.id}
                                  selected={selectedVariant?.id === variant.id}
                                  disabled={!variant.available}
                                  data-product-id={bundleProduct.id}
                                  data-price={variant.price}
                                  data-compare-at-price={variant.compare_at_price || ''}
                                  data-image={variant.image || bundleProduct.featured_image || bundleProduct.images[0] || ''}
                                  data-title={variant.title}
                                >
                                  {variantOptionsLabel(variant) || variant.title}
                                </option>
                              ))}
                            </select>
                          ) : (
                            <input class="bundle-variant-id" type="hidden" value={selectedVariant?.id || ''} />
                          )}
                          <input type="hidden" name={`bundle_products[${index}][product_id]`} value={bundleProduct.id} />
                          <input class="bundle-form-variant-id" type="hidden" name={`bundle_products[${index}][variant_id]`} value={selectedVariant?.id || ''} />

                          <div class="bundle-quantity-controls flex w-fit items-stretch border border-secondary-border">
                            <button type="button" class="bundle-quantity-minus px-3 py-2 text-sm transition-colors hover:bg-secondary-border/10" aria-label={`Decrease ${bundleProduct.name} quantity`}>-</button>
                            <input class="bundle-quantity-input w-14 border-x border-secondary-border/50 text-center text-sm focus:outline-none" name={`bundle_products[${index}][quantity]`} type="number" min="1" value="1" />
                            <button type="button" class="bundle-quantity-plus px-3 py-2 text-sm transition-colors hover:bg-secondary-border/10" aria-label={`Increase ${bundleProduct.name} quantity`}>+</button>
                          </div>
                        </div>
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          )}

          {wholesalePrices.length > 0 && !isBundle && (
            <div class="wholesale-section mb-6 border border-secondary-border/40">
              <div class="border-b border-secondary-border/30 bg-secondary-border/5 px-4 py-3">
                <span class="text-sm font-medium text-accent">Buy More, Pay Less!</span>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                  <thead class="bg-secondary-border/5 text-secondary">
                    <tr>
                      <th class="px-3 py-3 text-center font-medium">Quantity</th>
                      <th class="px-3 py-3 text-center font-medium">Unit price</th>
                      <th class="px-3 py-3 text-center font-medium">Saving per unit</th>
                    </tr>
                  </thead>
                  <tbody>
                    {wholesalePrices.map((tier) => (
                      <tr class="border-t border-secondary-border/30">
                        <td class="px-3 py-3 text-center text-accent">
                          {tier.maximum_quantity ? `${tier.minimum_quantity} - ${tier.maximum_quantity}` : `${tier.minimum_quantity} or more`}
                        </td>
                        <td class="px-3 py-3 text-center text-accent">{formatMoney(tier.unit_price, currency)}</td>
                        <td class="px-3 py-3 text-center text-accent">{formatMoney(tier.saving_per_unit, currency)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          {selectableOptions.length > 0 && !isBundle && (
            <div id="product-options" class="mb-6">
              {selectableOptions.map((option) => (
                <div class="mb-4" data-option-group={option.name}>
                  <label class="mb-2 block text-sm font-medium">{option.name}</label>
                  <div class:list={[option.type === 'swatch' ? 'flex flex-wrap gap-3' : 'grid grid-cols-2 gap-3']}>
                    {option.values.map((value) => {
                      const available = optionValueIsAvailable(option, value.name);
                      const image = optionValueImage(option, value.name);
                      const colors = value.metadata?.colors || ['#E2E0DC'];

                      return option.type === 'swatch' ? (
                        <button
                          type="button"
                          class:list={[
                            'product-option-button relative h-10 w-10 overflow-hidden border border-secondary-border transition-all hover:border-primary',
                            !available && 'cursor-not-allowed opacity-30'
                          ]}
                          data-option-name={option.name}
                          data-option-value={value.name}
                          data-sold-out={!available}
                          aria-label={value.name}
                          title={value.name}
                        >
                          <span class="flex h-full w-full flex-col">
                            <span class="block min-h-0 flex-1" style={`background: ${colors[0]};`}></span>
                            <span class="block min-h-0 flex-1" style={`background: ${colors[1] || colors[0]};`}></span>
                          </span>
                        </button>
                      ) : (
                        <button
                          type="button"
                          class:list={[
                            'product-option-button relative flex min-h-12 w-full items-center overflow-hidden border border-secondary-border text-sm font-medium text-accent transition-all hover:border-primary',
                            image ? 'justify-start gap-4' : 'justify-center px-4 text-center',
                            !available && 'cursor-not-allowed opacity-30'
                          ]}
                          data-option-name={option.name}
                          data-option-value={value.name}
                          data-sold-out={!available}
                        >
                          {image && (
                            <div class="h-14 w-14 flex-shrink-0 overflow-hidden bg-secondary-border/10">
                              <img src={image} alt={value.name} class="h-full w-full object-cover" loading="lazy" />
                            </div>
                          )}
                          <span class:list={[image && 'pr-3']}>{value.name}</span>
                          <span class="option-active-indicator absolute bottom-0 right-0 hidden" aria-hidden="true">
                            <span class="block h-0 w-0 border-b-[24px] border-l-[24px] border-b-primary border-l-transparent"></span>
                            <svg class="absolute h-2.5 w-2.5 text-white" style="left: 12px; top: 11px;" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                            </svg>
                          </span>
                        </button>
                      );
                    })}
                  </div>
                </div>
              ))}
            </div>
          )}

          <div id="product-stock-status" class="mb-4 hidden text-sm text-secondary">
            <span data-stock-count></span>
            <span data-stock-label>pieces available</span>
          </div>

          {customOptions.length > 0 && (
            <div class="mb-6">
              {customOptions.map((option) => (
                <div class="mb-4">
                  <label class="mb-2 block text-sm font-medium" for={`custom-option-${option.id}`}>
                    {option.name}
                  </label>
                  {option.type === 'textarea' ? (
                    <textarea
                      id={`custom-option-${option.id}`}
                      name={`options[${option.id}]`}
                      class="w-full border border-secondary-border bg-card px-3 py-3 text-sm focus:border-primary focus:outline-none"
                      maxlength="255"
                      rows="4"
                      required={option.required}
                    ></textarea>
                  ) : (
                    <input
                      id={`custom-option-${option.id}`}
                      type={optionType(option.type)}
                      name={`options[${option.id}]`}
                      class="w-full border border-secondary-border bg-card px-3 py-3 text-sm focus:border-primary focus:outline-none"
                      required={option.required}
                    />
                  )}
                </div>
              ))}
            </div>
          )}

          {product.variants.length > 1 && product.has_only_default_variant && !isBundle && (
            <div class="mb-4 text-sm text-secondary">
              {product.variants.map((variant) => (
                <p>{variantOptionsLabel(variant)}</p>
              ))}
            </div>
          )}

          {!isBundle && (
          <div class="mb-6">
            <label class="mb-2 block text-sm font-medium" for="product-quantity">Quantity</label>
            <div class="flex items-center gap-4">
              <div class:list={['flex items-stretch border border-secondary-border', !product.available && 'opacity-50']}>
                <button id="quantity-minus" class="flex items-center justify-center px-4 transition-colors hover:bg-secondary-border/10" type="button" disabled={!product.available}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
                <input
                  id="product-quantity"
                  class="w-16 border-x border-secondary-border/50 py-3 text-center focus:outline-none"
                  name="quantity"
                  type="number"
                  min="1"
                  value="1"
                  disabled={!product.available}
                />
                <button id="quantity-plus" class="flex items-center justify-center px-4 transition-colors hover:bg-secondary-border/10" type="button" disabled={!product.available}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
              </div>
            </div>
          </div>
          )}

          <div class="space-y-3">
            {product.available ? (
              <>
                <button
                  type="button"
                  id="btn-add-to-cart"
                  class="w-full border-2 border-primary bg-transparent px-8 py-4 text-sm font-semibold uppercase tracking-widest text-primary transition-all hover:bg-primary hover:text-white"
                >
                  Add to cart
                </button>
                <button
                  type="button"
                  id="btn-buynow"
                  class="flex w-full items-center justify-center gap-2 border-2 border-primary bg-primary px-8 py-4 text-sm font-semibold uppercase tracking-widest text-white transition-all hover:bg-primary/90"
                >
                  Buy now
                </button>
              </>
            ) : (
              <button class="w-full cursor-not-allowed border-2 border-secondary-border bg-secondary-border px-8 py-4 text-sm font-semibold uppercase tracking-widest text-secondary" disabled>
                Sold Out
              </button>
            )}
          </div>
        </form>

        {product.description && (
          <div class="prose-jugra mt-8 text-secondary" set:html={sanitizeHtml(product.description)} />
        )}
      </div>
    </div>

    {reviews.length > 0 && (
      <section class="mt-14 border-t border-secondary-border/40 px-5 py-12 md:px-0 md:py-16">
        <div class="mb-14 text-center">
          <h2 class="mb-4 font-display text-3xl font-semibold text-accent md:text-4xl">Customer Reviews</h2>
          <div class="flex items-center justify-center gap-2 text-sm text-secondary">
            <span class="flex items-center gap-0.5" aria-label={`${averageRating.toFixed(1)} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, index) => (
                <span class={index < roundedAverageRating ? 'text-[#d9a441]' : 'text-secondary-border'} aria-hidden="true">★</span>
              ))}
            </span>
            <span>{averageRating.toFixed(0)} ({reviewCount} {reviewCount === 1 ? 'review' : 'reviews'})</span>
          </div>
        </div>
        <div>
          {reviews.map((review) => (
            <article class="border-b border-secondary-border/40 py-8">
              <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-start">
                <div>
                  <p class="mb-8 flex items-center gap-1.5 text-xs text-secondary">
                    <span class="inline-flex h-3 w-3 items-center justify-center rounded-full bg-green-600 text-[8px] leading-none text-white" aria-hidden="true">✓</span>
                    Verified buyer
                  </p>
                  <p class="leading-relaxed text-secondary">{review.description}</p>
                </div>
                <div class="md:text-right">
                  <div class="mb-1 flex items-center gap-0.5 md:justify-end" aria-label={`${review.rating} out of 5 stars`}>
                    {Array.from({ length: 5 }).map((_, index) => (
                      <span class={index < Math.round(Math.max(0, Math.min(5, review.rating))) ? 'text-[#d9a441]' : 'text-secondary-border'} aria-hidden="true">★</span>
                    ))}
                  </div>
                  <p class="text-xs text-secondary">{reviewDate(review.created_at)}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </div>
</section>

<script>
  import { CheckoutService } from '@services/CheckoutService';
  import { cartStore } from '@stores/cartStore';
  import type { ShoppegoBundleProduct, ShoppegoProduct, ShoppegoProductVariant, ShoppegoWholesalePrice } from '@models/shoppego';

  function formatMoney(amount: number, currency: { symbol?: string; decimal_digits?: number; thousand_separator?: string }) {
    const decimals = Number.isInteger(currency.decimal_digits) ? (currency.decimal_digits as number) : 2;
    const fixed = Number(amount || 0).toFixed(decimals);
    const [whole, fraction] = fixed.split('.');
    const grouped = whole.replace(/\B(?=(\d{3})+(?!\d))/g, currency.thousand_separator || ',');
    return `${currency.symbol || ''}${grouped}${decimals > 0 ? `.${fraction}` : ''}`;
  }

  const form = document.getElementById('product-form') as HTMLFormElement | null;

  if (form) {
    const product = JSON.parse(form.dataset.product || '{}') as ShoppegoProduct;
    const currency = JSON.parse(form.dataset.currency || '{}');
    const selectedVariantInput = document.getElementById('selected-variant-id') as HTMLInputElement | null;
    const priceEl = document.getElementById('product-price');
    const compareEl = document.getElementById('product-compare-price');
    const stockEl = document.getElementById('product-stock-status') as HTMLElement | null;
    const stockCountEl = stockEl?.querySelector<HTMLElement>('[data-stock-count]') || null;
    const alertEl = document.getElementById('product-alert');
    const quantityInput = document.getElementById('product-quantity') as HTMLInputElement | null;
    const optionButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.product-option-button'));
    const addButton = document.getElementById('btn-add-to-cart') as HTMLButtonElement | null;
    const buyButton = document.getElementById('btn-buynow') as HTMLButtonElement | null;
    const selections: Record<string, string> = {};
    const isBundle = Boolean(product.is_bundle && product.bundle_products?.length);
    const wholesalePrices = (product.wholesale_prices || []) as ShoppegoWholesalePrice[];
    let activeGalleryIndex = 0;

    function syncStock(variant: ShoppegoProductVariant | null) {
      const shouldShowStock = Boolean(variant?.available && variant.manage_stock && typeof variant.inventory_quantity === 'number');
      stockEl?.classList.toggle('hidden', !shouldShowStock);
      if (stockCountEl && shouldShowStock) {
        stockCountEl.textContent = String(variant?.inventory_quantity || 0);
      }
    }

    function findVariant(): ShoppegoProductVariant | null {
      const selectableOptions = (product.options || []).filter((option) => {
        return ['radio', 'select', 'swatch'].includes(option.type) && option.name !== 'Default' && !product.has_only_default_variant;
      });

      if (selectableOptions.length && Object.keys(selections).length !== selectableOptions.length) {
        return null;
      }

      return (product.variants || []).find((variant) => {
        return Object.entries(selections).every(([name, value]) => variant.options?.[name] === value);
      }) || product.variants?.[0] || null;
    }

    function showGalleryIndex(index: number) {
      const slides = Array.from(document.querySelectorAll('.product-gallery-slide'));
      if (!slides.length) return;

      activeGalleryIndex = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle('hidden', slideIndex !== activeGalleryIndex);
      });
      document.querySelectorAll<HTMLButtonElement>('.product-gallery-thumb').forEach((thumb, thumbIndex) => {
        thumb.classList.toggle('border-secondary-border', thumbIndex === activeGalleryIndex);
        thumb.classList.toggle('border-transparent', thumbIndex !== activeGalleryIndex);
      });
    }

    function showGalleryImage(image: string) {
      let matchedIndex = -1;
      document.querySelectorAll<HTMLElement>('.product-gallery-slide').forEach((slide, slideIndex) => {
        if (slide.dataset.galleryImage === image) matchedIndex = slideIndex;
      });

      if (matchedIndex < 0) return;
      showGalleryIndex(matchedIndex);
    }

    function syncVariant() {
      const variant = findVariant();
      if (!variant) return;

      if (selectedVariantInput) selectedVariantInput.value = String(variant.id);
      if (priceEl) priceEl.textContent = formatMoney(variant.price, currency);
      if (compareEl) {
        const hasCompare = variant.compare_at_price && variant.compare_at_price > variant.price;
        compareEl.textContent = hasCompare ? formatMoney(variant.compare_at_price as number, currency) : '';
        compareEl.classList.toggle('hidden', !hasCompare);
      }
      syncStock(variant);
      if (variant.image) showGalleryImage(variant.image);
      syncWholesalePrice();
      document.querySelectorAll<HTMLButtonElement>('#btn-add-to-cart, #btn-buynow').forEach((button) => {
        button.disabled = !variant.available;
        button.classList.toggle('opacity-50', !variant.available);
        button.classList.toggle('cursor-not-allowed', !variant.available);
      });
    }

    function getWholesaleTier(quantity: number): ShoppegoWholesalePrice | null {
      return wholesalePrices.find((tier) => {
        const aboveMinimum = quantity >= tier.minimum_quantity;
        const belowMaximum = !tier.maximum_quantity || quantity <= tier.maximum_quantity;
        return aboveMinimum && belowMaximum;
      }) || null;
    }

    function syncWholesalePrice() {
      if (!wholesalePrices.length || isBundle || !priceEl) return;

      const tier = getWholesaleTier(getQuantity());
      const variant = findVariant();
      const basePrice = variant?.price ?? product.price;
      priceEl.textContent = formatMoney(tier?.unit_price ?? basePrice, currency);
    }

    optionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (button.dataset.soldOut === 'true') return;

        const name = button.dataset.optionName;
        const value = button.dataset.optionValue;
        if (!name || !value) return;

        selections[name] = value;
        button.closest('[data-option-group]')?.querySelectorAll('.product-option-button').forEach((sibling) => {
          sibling.classList.remove('border-primary');
          sibling.classList.add('border-secondary-border');
          sibling.querySelector('.option-active-indicator')?.classList.add('hidden');
        });
        button.classList.add('border-primary');
        button.classList.remove('border-secondary-border');
        button.querySelector('.option-active-indicator')?.classList.remove('hidden');
        alertEl?.classList.add('hidden');
        syncVariant();
      });
    });

    document.getElementById('quantity-minus')?.addEventListener('click', () => {
      if (!quantityInput) return;
      quantityInput.value = String(Math.max(1, Number(quantityInput.value || 1) - 1));
      syncWholesalePrice();
    });

    document.getElementById('quantity-plus')?.addEventListener('click', () => {
      if (!quantityInput) return;
      quantityInput.value = String(Math.max(1, Number(quantityInput.value || 1) + 1));
      syncWholesalePrice();
    });

    quantityInput?.addEventListener('change', () => {
      quantityInput.value = String(Math.max(1, Number(quantityInput.value || 1)));
      syncWholesalePrice();
    });

    document.querySelectorAll<HTMLButtonElement>('.product-gallery-thumb').forEach((thumb) => {
      thumb.addEventListener('click', () => {
        showGalleryIndex(Number(thumb.dataset.galleryIndex || 0));
      });
    });

    document.getElementById('carousel-prev')?.addEventListener('click', () => {
      showGalleryIndex(activeGalleryIndex - 1);
    });

    document.getElementById('carousel-next')?.addEventListener('click', () => {
      showGalleryIndex(activeGalleryIndex + 1);
    });

    function getSelectedVariant(): ShoppegoProductVariant | null {
      const variant = findVariant();

      if (!variant || !selectedVariantInput?.value) {
        alertEl?.classList.remove('hidden');
        return null;
      }

      if (!variant.available) {
        alertEl?.classList.remove('hidden');
        if (alertEl) alertEl.textContent = 'This option is currently unavailable.';
        return null;
      }

      if (!form?.reportValidity()) return null;
      alertEl?.classList.add('hidden');
      return variant;
    }

    function getQuantity(): number {
      return Math.max(1, Number(quantityInput?.value || 1));
    }

    async function createHostedBundleCheckout() {
      const lines = getBundleLines();
      if (!lines || !form) return null;

      const checkoutUrl = form.dataset.bundleCheckoutUrl || '/api/bundle-checkout';
      const body = new FormData(form);
      body.set('quantity', String(getQuantity()));
      body.set('express', '1');

      const response = await fetch(checkoutUrl, {
        method: 'POST',
        headers: {
          Accept: 'application/json'
        },
        body
      });
      const payload = await response.json().catch(() => null) as { checkout_url?: string; error?: string } | null;

      if (!response.ok || !payload?.checkout_url) {
        throw new Error(payload?.error || 'Bundle checkout could not be created.');
      }

      return payload.checkout_url;
    }

    function getBundleVariant(bundleProduct: ShoppegoBundleProduct, variantId: number): ShoppegoProductVariant | null {
      return bundleProduct.variants.find((variant) => variant.id === variantId) || null;
    }

    function getBundleLines(): Array<{ bundleProduct: ShoppegoBundleProduct; variant: ShoppegoProductVariant; quantity: number }> | null {
      if (!isBundle || !product.bundle_products?.length) return null;

      const lines: Array<{ bundleProduct: ShoppegoBundleProduct; variant: ShoppegoProductVariant; quantity: number }> = [];
      const lineEls = Array.from(document.querySelectorAll<HTMLElement>('[data-bundle-line]'));

      for (const lineEl of lineEls) {
        const index = Number(lineEl.dataset.bundleIndex || 0);
        const bundleProduct = product.bundle_products[index];
        const select = lineEl.querySelector<HTMLSelectElement>('.bundle-variant-select');
        const hiddenInput = lineEl.querySelector<HTMLInputElement>('.bundle-variant-id');
        const formVariantInput = lineEl.querySelector<HTMLInputElement>('.bundle-form-variant-id');
        const quantityField = lineEl.querySelector<HTMLInputElement>('.bundle-quantity-input');
        const variantId = Number(select?.value || hiddenInput?.value || 0);
        const variant = bundleProduct ? getBundleVariant(bundleProduct, variantId) : null;

        if (!bundleProduct || !variant) {
          if (alertEl) {
            alertEl.textContent = 'Please select a bundle option.';
            alertEl.classList.remove('hidden');
          }
          return null;
        }

        if (!variant.available) {
          if (alertEl) {
            alertEl.textContent = 'One of the bundle items is currently unavailable.';
            alertEl.classList.remove('hidden');
          }
          return null;
        }

        lines.push({
          bundleProduct,
          variant,
          quantity: Math.max(1, Number(quantityField?.value || 1))
        });

        if (formVariantInput) formVariantInput.value = String(variant.id);
        if (quantityField) quantityField.value = String(Math.max(1, Number(quantityField.value || 1)));
      }

      if (!lines.length) {
        alertEl?.classList.remove('hidden');
        return null;
      }

      alertEl?.classList.add('hidden');
      return lines;
    }

    document.querySelectorAll<HTMLButtonElement>('.bundle-quantity-minus, .bundle-quantity-plus').forEach((button) => {
      button.addEventListener('click', () => {
        const input = button.closest('[data-bundle-line]')?.querySelector<HTMLInputElement>('.bundle-quantity-input');
        if (!input) return;

        const next = button.classList.contains('bundle-quantity-plus')
          ? Number(input.value || 1) + 1
          : Number(input.value || 1) - 1;
        input.value = String(Math.max(1, next));
      });
    });

    document.querySelectorAll<HTMLSelectElement>('.bundle-variant-select').forEach((select) => {
      select.addEventListener('change', () => {
        const selected = select.selectedOptions[0];
        const line = select.closest<HTMLElement>('[data-bundle-line]');
        const formVariantInput = line?.querySelector<HTMLInputElement>('.bundle-form-variant-id');
        const price = Number(selected?.dataset.price || 0);
        const compareAtPrice = Number(selected?.dataset.compareAtPrice || 0);
        const hasCompare = compareAtPrice > price;

        const priceEl = line?.querySelector<HTMLElement>('.bundle-price');
        const compareEl = line?.querySelector<HTMLElement>('.bundle-discount-price-single');
        const savedEl = line?.querySelector<HTMLElement>('.bundle-saved-price-variant');
        const image = selected?.dataset.image;

        if (priceEl) priceEl.textContent = formatMoney(price, currency);
        if (compareEl) {
          compareEl.textContent = hasCompare ? formatMoney(compareAtPrice, currency) : '';
          compareEl.classList.toggle('hidden', !hasCompare);
        }
        if (savedEl) {
          savedEl.textContent = hasCompare ? `(Save ${formatMoney(compareAtPrice - price, currency)})` : '';
          savedEl.classList.toggle('hidden', !hasCompare);
        }
        if (image) {
          const img = line?.querySelector<HTMLImageElement>('.bundle-thumbnails img');
          if (img) img.src = image;
        }
        if (formVariantInput) formVariantInput.value = select.value;
      });
    });

    addButton?.addEventListener('click', () => {
      if (isBundle) {
        const lines = getBundleLines();
        if (!lines) return;

        cartStore.addBundle({
          product,
          quantity: getQuantity(),
          bundleProducts: lines.map((line) => ({
            productId: line.bundleProduct.id,
            variantId: line.variant.id,
            quantity: line.quantity
          }))
        });
        window.dispatchEvent(new CustomEvent('jugra:open-cart'));

        if (addButton) {
          addButton.textContent = 'Added';
          window.setTimeout(() => {
            addButton.textContent = 'Add to cart';
          }, 1200);
        }
        return;
      }

      const variant = getSelectedVariant();
      if (!variant) return;

      cartStore.add({
        product,
        variant,
        quantity: getQuantity()
      });
      window.dispatchEvent(new CustomEvent('jugra:open-cart'));

      if (addButton) {
        addButton.textContent = 'Added';
        window.setTimeout(() => {
          addButton.textContent = 'Add to cart';
        }, 1200);
      }
    });

    buyButton?.addEventListener('click', async () => {
      if (isBundle) {
        if (!buyButton) return;

        try {
          buyButton.disabled = true;
          buyButton.textContent = 'Opening checkout...';
          const checkoutUrl = await createHostedBundleCheckout();
          if (checkoutUrl) window.location.href = checkoutUrl;
        } catch (error) {
          const message = error instanceof Error ? error.message : 'Bundle checkout could not be created.';
          if (alertEl) {
            alertEl.textContent = message;
            alertEl.classList.remove('hidden');
          }
          buyButton.disabled = false;
          buyButton.textContent = 'Buy now';
        }
        return;
      }

      const variant = getSelectedVariant();
      if (!variant || !buyButton) return;

      buyButton.disabled = true;
      buyButton.textContent = 'Opening checkout...';

      try {
        const checkout = await CheckoutService.createCheckout({
          lines: [{ variant_id: variant.id, quantity: getQuantity() }]
        });
        window.location.href = checkout.checkout_url;
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Checkout could not be created.';
        if (alertEl) {
          alertEl.textContent = message;
          alertEl.classList.remove('hidden');
        }
        buyButton.disabled = false;
        buyButton.textContent = 'Buy now';
      }
    });

    document.querySelectorAll<HTMLButtonElement>('#btn-add-to-cart, #btn-buynow').forEach((button) => {
      button.addEventListener('click', () => {
        if (!isBundle && !selectedVariantInput?.value) {
          alertEl?.classList.remove('hidden');
        }
      });
    });
  }
</script>
